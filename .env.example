# Copy this file to .env and fill in your values.
# Never commit .env — it contains live credentials.

# Supabase project URL (found in Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — grants full DB access, keep this secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Path where the model weights file is stored locally
# The app will download from Supabase Storage if this file is missing
MODEL_PATH=/app/models/fin_embedder.pt

# Name of the Supabase Storage bucket holding the model weights
SUPABASE_STORAGE_BUCKET=finfinder

# API key required for all routes except /health.
# Leave unset to disable authentication (useful for local development).
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-api-key-here
