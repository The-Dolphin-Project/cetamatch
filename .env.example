# Copy this file to .env and fill in your values.
# Never commit .env — it contains live credentials.

# Supabase project URL (found in Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — grants full DB access, keep this secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API key required for all routes except /health.
# Leave unset to disable authentication (useful for local development).
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-api-key-here
